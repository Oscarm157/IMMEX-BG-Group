# --- Base de datos (Neon, nueva para BG) ---
DATABASE_URL=postgresql://user:pass@host-pooler.neon.tech/db?sslmode=require

# --- Auth del admin ---
CRM_SECRET=                 # 32+ chars aleatorios para firmar sesiones
CRM_ADMIN_EMAIL=           # admin semilla (primer login)
CRM_ADMIN_PASSWORD=        # password semilla (se hashea al sembrar)

# --- IA (chatbot + resúmenes de leads + borradores de blog) ---
ANTHROPIC_API_KEY=

# --- Email (notificación de leads) ---
RESEND_API_KEY=
MAIL_FROM=onboarding@resend.dev   # remitente verificado en Resend
LEAD_RECIPIENT=contacto@bgc.mx     # bandeja que recibe los leads

# --- Almacenamiento de archivos del CRM ---
BLOB_READ_WRITE_TOKEN=

# --- Analítica (públicas; el sitio no las muestra si están vacías) ---
NEXT_PUBLIC_GA_ID=          # GA4, formato G-XXXXXXX
NEXT_PUBLIC_FB_PIXEL_ID=    # Pixel de Meta (numérico)

# --- Opcionales ---
LEAD_WEBHOOK_URL=          # POST de cada lead a Make/Zapier/n8n

# --- Campus (capacitación, subdominio campus.bgconsultingroup.com) ---
CAMPUS_SECRET=             # 32+ chars aleatorios para firmar sesiones del campus (distinto de CRM_SECRET)
SUPADATA_API_KEY=          # extracción de transcript de YouTube para autogenerar quizzes
